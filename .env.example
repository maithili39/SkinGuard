# Copy to .env and adjust.
# Local dev (no Postgres needed yet):
DATABASE_URL=sqlite:///./skinguard.db

# Later, when you switch to Postgres (e.g. via Docker):
# DATABASE_URL=postgresql+psycopg2://skinguard:skinguard@localhost:5432/skinguard

# Fuzzy match threshold (0-100). Below this, an ingredient is "unmatched".
MATCH_THRESHOLD=82

# JWT secret key — CHANGE THIS before any public deployment.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Max upload size for OCR images (bytes). Default = 8 MB.
MAX_UPLOAD_BYTES=8388608

# ── AI / ML Settings ──────────────────────────────────────────────────────────

# Gemini API key for Tier 1-A RAG Q&A + LLM-grounded ingredient explanations.
# Get your key at: https://aistudio.google.com/app/apikey
# Leave blank to disable — the app gracefully falls back to template explanations.
GEMINI_API_KEY=

# Gemini model to use (default: gemini-2.5-pro — best capability).
# Alternatives: gemini-1.5-flash (faster, cheaper), gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-pro

# Sentence-transformer model for semantic ingredient matching (Tier 1-B).
# Default downloads ~80 MB on first run, then cached locally.
# Alternatives: all-mpnet-base-v2 (slower, higher accuracy), paraphrase-MiniLM-L6-v2
EMBED_MODEL=all-MiniLM-L6-v2

# Cosine similarity threshold for the embedding matcher (0.0–1.0).
# Tokens below this threshold are passed to RapidFuzz as a tiebreaker.
EMBED_THRESHOLD=0.82
