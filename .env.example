# Copy this file to .env and fill in values before running locally or with Docker.
# cp .env.example .env

# ── Required in production / Docker ──────────────────────────────────────────

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PostgreSQL password (Docker compose will error if this is not set).
POSTGRES_PASSWORD=changeme

# ── Database ──────────────────────────────────────────────────────────────────

# Local dev default (SQLite, zero infra):
DATABASE_URL=sqlite:///./skinguard.db

# Production / Docker (uncomment and set POSTGRES_PASSWORD above):
# DATABASE_URL=postgresql+psycopg2://skinguard:${POSTGRES_PASSWORD}@db:5432/skinguard

# ── Environment ───────────────────────────────────────────────────────────────

# "development" or "production". Production mode warns if SQLite is detected.
ENV=development

# ── Caching (optional) ────────────────────────────────────────────────────────

# The app degrades gracefully when Redis is unavailable — caching is silently skipped.
REDIS_URL=redis://localhost:6379/0

# ── OCR ───────────────────────────────────────────────────────────────────────

# "tesseract" (default, works offline) or "google_cloud" (production quality).
OCR_PROVIDER=tesseract

# Path to GCP service account JSON — only needed when OCR_PROVIDER=google_cloud.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── AI / LLM (optional) ───────────────────────────────────────────────────────
# Powers richer ingredient explanations and the /chat endpoint. Falls back to
# deterministic template explanations when no key is set — fully functional without it.
# Provider is auto-selected: Groq if GROQ_API_KEY is set, else Gemini. Force one
# with LLM_PROVIDER=groq|gemini when both keys are present.

# Groq (recommended — fast, OpenAI-compatible). Get a key at https://console.groq.com
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (alternative). Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-pro

# Optional: force a provider when both keys are present (groq | gemini).
# LLM_PROVIDER=groq

# ── Email / Notifications (optional) ──────────────────────────────────────────

# Resend API Key for sending password reset emails.
# If not set, reset links are printed to the backend console (stdout) for local development.
# RESEND_API_KEY=

# ── Matching ──────────────────────────────────────────────────────────────────

# Fuzzy match confidence threshold (0-100).
# Tokens scoring below this are reported as unmatched rather than guessed.
MATCH_THRESHOLD=82

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated allowed origins. Add your deployed frontend URL in production.
SKINGUARD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Upload limits ────────────────────────────────────────────────────────────

# Maximum image upload size in bytes. Default is 8 MB.
# MAX_UPLOAD_BYTES=8388608

# ── Docker / Gunicorn ─────────────────────────────────────────────────────────

# Number of Gunicorn workers in Docker. Rule of thumb: 2 × CPU cores + 1.
GUNICORN_WORKERS=4
