# Copy to .env and adjust.
# Local dev (no Postgres needed yet):
DATABASE_URL=sqlite:///./skinguard.db

# Later, when you switch to Postgres (e.g. via Docker):
# DATABASE_URL=postgresql+psycopg2://skinguard:skinguard@localhost:5432/skinguard

# Fuzzy match threshold (0-100). Below this, an ingredient is "unmatched".
MATCH_THRESHOLD=82

# JWT secret key — CHANGE THIS before any public deployment.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Max upload size for OCR images (bytes). Default = 8 MB.
MAX_UPLOAD_BYTES=8388608
